generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id            String              @id @default(cuid())
  slug          String              @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  isActive      Boolean             @default(true)
  dataVersion   Int                 @default(1)
  aiNarrative   AssetAiNarrative?
  blockchain    AssetBlockchain[]
  compliance    AssetCompliance?
  events        AssetEvent[]
  grade         AssetGrade?
  history       AssetHistory[]
  identity      AssetIdentity?
  institutional AssetInstitutional?
  liquidity     AssetLiquidity?
  market        AssetMarket?
  reserve       AssetReserve?
  risk          AssetRisk?
  sources       AssetSource[]
  yield         AssetYield?

  @@index([isActive])
  @@index([slug])
}

model AssetIdentity {
  id          String    @id @default(cuid())
  assetId     String    @unique
  name        String
  symbol      String
  fullName    String?
  description String?
  category    String
  subcategory String?
  logoUrl     String?
  websiteUrl  String?
  docsUrl     String?
  twitterUrl  String?
  tags        String[]
  launchDate  DateTime?
  isin        String?
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([symbol])
}

model AssetMarket {
  id                String    @id @default(cuid())
  assetId           String    @unique
  tvl               Float?
  tvl7dChange       Float?
  tvl30dChange      Float?
  price             Float?
  priceChange24h    Float?
  marketCap         Float?
  volume24h         Float?
  circulatingSupply Float?
  totalSupply       Float?
  holderCount       Int?
  holderChange7d    Int?
  aumUsd            Float?
  lastUpdated       DateTime?
  sources           String[]
  confidence        String?
  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetRisk {
  id                 String    @id @default(cuid())
  assetId            String    @unique
  overallScore       Int?
  overallLevel       String?
  smartContractRisk  Int?
  counterpartyRisk   Int?
  liquidityRisk      Int?
  regulatoryRisk     Int?
  marketRisk         Int?
  concentrationRisk  Int?
  riskFactors        String[]
  mitigants          String[]
  lastAssessed       DateTime?
  assessmentMethod   String?
  methodologyVersion String?
  asset              Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetReserve {
  id                     String    @id @default(cuid())
  assetId                String    @unique
  backingType            String?
  backingDescription     String?
  collateralizationRatio Float?
  custodian              String?
  custodianUrl           String?
  hasProofOfReserves     Boolean   @default(false)
  porOracleAddress       String?
  porOracleChain         String?
  lastAuditDate          DateTime?
  lastAuditUrl           String?
  auditor                String?
  reserveBreakdown       Json?
  redemptionAsset        String?
  asset                  Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetYield {
  id               String    @id @default(cuid())
  assetId          String    @unique
  currentYield     Float?
  yieldType        String?
  yieldFrequency   String?
  yieldBenchmark   String?
  yieldVsBenchmark Float?
  yieldAvg7d       Float?
  yieldAvg30d      Float?
  yieldAvg90d      Float?
  yieldMin52w      Float?
  yieldMax52w      Float?
  yieldStdDev30d   Float?
  nextYieldDate    DateTime?
  yieldCurrency    String    @default("USD")
  asset            Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetInstitutional {
  id                String  @id @default(cuid())
  assetId           String  @unique
  issuerName        String?
  issuerType        String?
  issuerCountry     String?
  fundManager       String?
  legalStructure    String?
  minimumInvestment Float?
  managementFee     Float?
  performanceFee    Float?
  fundAdmin         String?
  transferAgent     String?
  targetInvestors   String?
  prospectuUrl      String?
  metadata          Json?
  asset             Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetBlockchain {
  id                      String    @id @default(cuid())
  assetId                 String
  chain                   String
  chainId                 Int?
  contractAddress         String
  tokenStandard           String?
  isTransferable          Boolean   @default(true)
  hasWhitelist            Boolean   @default(false)
  hasTransferRestrictions Boolean   @default(false)
  explorerUrl             String?
  deployedAt              DateTime?
  isVerified              Boolean   @default(false)
  asset                   Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, chain])
  @@index([chain])
  @@index([contractAddress])
}

model AssetHistory {
  id                 String   @id @default(cuid())
  assetId            String
  timestamp          DateTime @default(now())
  tvl                Float?
  yield              Float?
  price              Float?
  holderCount        Int?
  riskScore          Int?
  volume24h          Float?
  source             String?
  methodologyVersion String?
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, timestamp])
}

model AssetAiNarrative {
  id            String    @id @default(cuid())
  assetId       String    @unique
  summary       String?
  opportunities String[]
  risks         String[]
  outlook       String?
  outlookReason String?
  confidence    String?
  keyMetrics    Json?
  compareTo     String[]
  generatedAt   DateTime?
  modelVersion  String?
  promptVersion Int       @default(1)
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetEvent {
  id          String   @id @default(cuid())
  assetId     String
  title       String
  description String?
  eventType   String
  severity    String   @default("info")
  occurredAt  DateTime
  sourceUrl   String?
  isVerified  Boolean  @default(false)
  onChainTx   String?
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, occurredAt])
}

model AssetCompliance {
  id                   String    @id @default(cuid())
  assetId              String    @unique
  regulatoryStatus     String?
  primaryRegulator     String?
  regulatoryFramework  String?
  kycRequired          Boolean   @default(true)
  accreditedOnly       Boolean   @default(false)
  blockedJurisdictions String[]
  allowedJurisdictions String[]
  sanctionsScreening   Boolean   @default(false)
  amlPolicy            String?
  lastComplianceCheck  DateTime?
  legalOpinionUrl      String?
  asset                Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetLiquidity {
  id                   String  @id @default(cuid())
  assetId              String  @unique
  redemptionType       String?
  redemptionPeriodDays Int?
  lockupPeriodDays     Int?
  earlyRedemptionFee   Float?
  minRedemptionAmount  Float?
  dexPairs             Json?
  onchainLiquidity     Float?
  bidAskSpread         Float?
  liquidityScore       Int?
  liquidityNotes       String?
  asset                Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetSource {
  id          String   @id @default(cuid())
  assetId     String
  layer       String
  field       String
  value       String?
  sourceUrl   String
  sourceType  String
  reliability Int
  status      String   @default("needs_review")
  checkedAt   DateTime @default(now())
  checkedBy   String?
  notes       String?
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([layer])
  @@index([field])
  @@index([sourceType])
  @@index([status])
}

model AssetGrade {
  id                String    @id @default(cuid())
  assetId           String    @unique
  grade             String
  score             Int
  completenessScore Int
  sourceScore       Int
  legalScore        Int
  reserveScore      Int
  liquidityScore    Int
  riskScore         Int
  blockers          String[]
  warnings          String[]
  reviewedBy        String?
  reviewedAt        DateTime?
  updatedAt         DateTime  @updatedAt
  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([grade])
  @@index([score])
}

model DataHealthCheck {
  id             String    @id @default(cuid())
  assetSlug      String
  layer          String
  status         String
  severity       String
  reason         String?
  resolutionType String?
  resolutionNote String?
  evidenceUrl    String?
  lastCheckedAt  DateTime  @default(now())
  nextCheckAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([assetSlug])
  @@index([layer])
  @@index([status])
  @@index([severity])
  @@index([lastCheckedAt])
  @@index([nextCheckAt])
}

model SourceHealth {
  id            String    @id @default(cuid())
  assetSlug     String
  layer         String
  field         String?
  url           String
  sourceType    String?
  reliability   Int?
  status        String
  httpStatus    Int?
  errorMessage  String?
  lastCheckedAt DateTime  @default(now())
  nextCheckAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([assetSlug])
  @@index([layer])
  @@index([status])
  @@index([lastCheckedAt])
  @@index([nextCheckAt])
}

model SyncLog {
  id            String    @id @default(cuid())
  assetSlug     String
  layer         String
  provider      String?
  status        String
  fieldsUpdated Json?
  fieldsFailed  Json?
  errorMessage  String?
  startedAt     DateTime
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([assetSlug])
  @@index([layer])
  @@index([status])
  @@index([startedAt])
}

model ReviewTask {
  id             String    @id @default(cuid())
  assetSlug      String
  layer          String
  priority       String
  reason         String
  status         String    @default("open")
  resolutionType String?
  resolutionNote String?
  evidenceUrl    String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([assetSlug])
  @@index([layer])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([resolvedAt])
}

model ApiRequest {
  id            String        @id @default(cuid())
  requestId     String        @unique
  endpoint      String
  method        String
  ipAddress     String?
  userAgent     String?
  paymentTxHash String?
  paymentAmount Float?
  paymentStatus PaymentStatus @default(NONE)
  responseCode  Int
  durationMs    Int
  timestamp     DateTime      @default(now())
  failureReason String?
  paymentFrom   String?

  @@index([endpoint])
  @@index([timestamp])
  @@index([paymentStatus])
}

model ApiKey {
  id         String     @id @default(cuid())
  keyHash    String     @unique
  prefix     String
  name       String
  tier       KeyTier    @default(STANDARD)
  isActive   Boolean    @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  usageLogs  UsageLog[]

  @@index([prefix])
  @@index([isActive])
}

model UsageLog {
  id           String   @id @default(cuid())
  endpoint     String
  method       String
  responseCode Int
  durationMs   Int
  apiKeyId     String?
  tier         String
  timestamp    DateTime @default(now())
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([endpoint])
  @@index([method])
  @@index([responseCode])
  @@index([apiKeyId])
  @@index([tier])
  @@index([timestamp])
}

model UsageDailyAggregate {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  endpoint          String
  method            String
  responseCode      Int
  tier              String
  requestCount      Int
  averageDurationMs Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, endpoint, method, responseCode, tier])
  @@index([date])
  @@index([endpoint])
  @@index([tier])
}

enum PaymentStatus {
  NONE
  PAID
  FAILED
  REFUNDED
}

enum KeyTier {
  FREE
  STANDARD
  PREMIUM
}
