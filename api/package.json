{
  "name": "@nexus-rwa/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "seed": "node --import tsx/esm prisma/seed.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && node --import tsx/esm prisma/seed.ts",
    "test:sync": "node --import tsx/esm src/scripts/test-sync.ts",
    "test:x402": "node --import tsx/esm src/scripts/test-x402.ts",
    "verify:assets": "node --import tsx/esm src/scripts/verify-assets.ts",
    "import:asset": "node --import tsx/esm src/scripts/import-asset-data.ts",
    "grade:asset": "node --import tsx/esm src/scripts/import-asset-data.ts",
    "validate:asset-files": "node --import tsx/esm src/scripts/validate-asset-files.ts",
    "validate:classification": "node --import tsx/esm src/scripts/validate-classification.ts",
    "validate:normalized-assets": "node --import tsx/esm src/scripts/validate-normalized-assets.ts",
    "import:asset-files": "node --import tsx/esm src/scripts/import-from-files.ts",
    "report:completeness": "node --import tsx/esm src/scripts/asset-completeness.ts",
    "meta:add": "node --import tsx/esm src/scripts/add-layer-meta.ts",
    "check:freshness": "node --import tsx/esm src/scripts/check-freshness.ts",
    "check:sources": "node --import tsx/esm src/scripts/check-sources.ts",
    "report:monitoring": "node --import tsx/esm src/scripts/report-monitoring.ts",
    "generate:monitoring": "node --import tsx/esm src/scripts/generate-monitoring.ts",
    "monitoring:clear": "node --import tsx/esm src/scripts/clear-monitoring.ts",
    "cleanup:legacy-truefi": "node --import tsx/esm src/scripts/deactivate-legacy-truefi.ts",
    "cleanup:legacy-credix": "node --import tsx/esm src/scripts/deactivate-legacy-credix.ts",
    "cleanup:legacy-ribbon": "node --import tsx/esm src/scripts/deactivate-legacy-ribbon-finance.ts",
    "create:api-key": "node --import tsx/esm src/scripts/create-api-key.ts",
    "check:api-key": "node --import tsx/esm src/scripts/check-api-key.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:coverage": "node --import tsx --experimental-test-coverage --test \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "typecheck": "prisma generate && tsc --noEmit"
  },
  "prisma": {
    "seed": "node --import tsx/esm prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.1",
    "@prisma/client": "^5.14.0",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/hono": "^2.11.0",
    "dotenv": "^16.6.1",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "hono": "^4.3.11",
    "ioredis": "^5.3.2",
    "node-cron": "^4.2.1",
    "pino": "^9.2.0",
    "prisma": "^5.14.0",
    "uuid": "^10.0.0",
    "viem": "^2.48.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
