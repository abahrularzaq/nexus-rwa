# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string (Neon, Supabase, RDS, atau local Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_rwa?sslmode=disable"

# ============================================
# REDIS
# ============================================
# Redis connection. Bisa pakai Upstash REST URL atau redis:// URL biasa.
# Local dev:   redis://localhost:6379
# Upstash:     rediss://default:<token>@<region>.upstash.io:6379
REDIS_URL="redis://localhost:6379"

# ============================================
# SERVER
# ============================================
PORT=3001
NODE_ENV="development"
API_VERSION="v1"

# Domain frontend yang di-whitelist CORS (di luar localhost & *.vercel.app).
# Bisa isi lebih dari satu origin (comma-separated).
# Contoh:
# FRONTEND_URL="https://nexus-rwa.com,https://www.nexus-rwa.com"
FRONTEND_URL="https://nexus-rwa.com"

# ============================================
# X402 PAYMENT
# ============================================
# WAJIB: "base" (mainnet) atau "base-sepolia" (testnet). Tanpa ini API gagal start.
X402_NETWORK="base"

# RPC utama (Alchemy/Infura). Fallback ke RPC_URL_* jika primary gagal (lihat api/src/lib/blockchain.ts).
BASE_MAINNET_RPC_URL="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
BASE_SEPOLIA_RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_KEY"

# Verifikasi native ETH via header X-Payment-Tx (lihat middleware X402).
PAYMENT_RECIPIENT="0xYOUR_MAINNET_WALLET"
PAYMENT_AMOUNT_ETH="0.001"

# Alamat wallet penerima (USDC di instruksi 402; fallback jika PAYMENT_RECIPIENT kosong).
# JANGAN PERNAH commit private key di file ini.
X402_RECEIVING_ADDRESS="0x0000000000000000000000000000000000000000"

# RPC fallback publik (dipakai jika BASE_*_RPC_URL kosong atau oleh viem fallback transport).
RPC_URL_ETHEREUM="https://eth.llamarpc.com"
RPC_URL_BASE="https://mainnet.base.org"
RPC_URL_BASE_SEPOLIA="https://sepolia.base.org"

# ============================================
# RATE LIMITING
# ============================================
# Catatan: belum di-wire ke kode (rate limiter masih pakai konstanta hardcoded).
# Disediakan untuk dokumentasi intent.
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="info"

# ============================================
# EXTERNAL DATA (rwa.xyz)
# ============================================
# Optional: Bearer token from https://app.rwa.xyz/tools/api/api-keys
# Without this key, rwa.xyz is skipped gracefully (DeFi Llama only).
RWA_XYZ_API_KEY=""

# ============================================
# BLOCK EXPLORERS (Etherscan & Basescan)
# ============================================
# Daftar gratis di https://etherscan.io/myapikey dan https://basescan.org/myapikey
ETHERSCAN_API_KEY=""
BASESCAN_API_KEY=""

# ============================================
# AI (Claude)
# ============================================
ANTHROPIC_API_KEY=""

# ============================================
# TESTING (optional)
# ============================================
# Override target URL untuk `npm run test:x402`. Default: http://localhost:3001
# API_URL="http://localhost:3001"
